# Copy to .env (gitignored) and fill in real values.
# Load into containers with: docker run --env-file .env ...

# --- video-transcriber: LLM summarization ---
# If set, summarize.py uses OpenRouter. Leave blank to use local Ollama.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Optional Ollama overrides (defaults shown)
# OLLAMA_MODEL=llama3
# OLLAMA_URL=http://host.docker.internal:11434/api/generate
